# Copy to .env.deploy (gitignored) and fill in values from the DreamHost panel.
#
# Panel → Manage Websites → lisaaufox.com → "Show more" for shell user + web directory.
# Panel → Secure Shell (SSH) for hostname and key setup.

# SSH target (often your domain or psXXXX.dreamhost.com)
DEPLOY_HOST=ps123456.dreamhost.com

# Shell username tied to the website (not your DreamHost account login)
DEPLOY_USER=your_shell_user

# Web root for lisaaufox.com on shared hosting (usually ~/lisaaufox.com)
DEPLOY_PATH=/home/your_shell_user/lisaaufox.com

# Optional: path to SSH private key if not using ~/.ssh/id_ed25519
# SSH_KEY=/Users/you/.ssh/dreamhost_ed25519

# Contact form — Formspree endpoint (server-side only; injected into contact-submit.php at deploy).
# Sign up at https://formspree.io, create a form, paste the endpoint URL here.
FORMSPREE_URL=https://formspree.io/f/your_form_id

# Legacy alias (deploy accepts either name):
# NEXT_PUBLIC_CONTACT_FORM_URL=https://formspree.io/f/your_form_id
